# Copy this file to deploy/.env when Docker Hub is unreachable, then adjust
# the mirror prefix or image names for a registry that works in your network.

# Official Docker Hub library images used by Dockerfiles:
# python, maven, eclipse-temurin, node, nginx.
# Example mirror prefix format:
# DOCKERHUB_LIBRARY_PREFIX=m.daocloud.io/docker.io/library/
DOCKERHUB_LIBRARY_PREFIX=

# Runtime images used directly by docker-compose.yml.
PGVECTOR_IMAGE=pgvector/pgvector:pg17
REDIS_IMAGE=redis:7-alpine
RABBITMQ_IMAGE=rabbitmq:3-management
PROMETHEUS_IMAGE=prom/prometheus:v2.55.0
GRAFANA_IMAGE=grafana/grafana:11.3.0

# AI model settings. Put your real key in deploy/.env, not in this example file.
MODEL_API_KEY=

# Host ports. Change these if a local service already uses the default port.
PGVECTOR_PORT=5433
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
AI_SERVICE_PORT=8000
BACKEND_PORT=8080
FRONTEND_PORT=5173
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Example mirror overrides:
# PGVECTOR_IMAGE=m.daocloud.io/docker.io/pgvector/pgvector:pg17
# REDIS_IMAGE=m.daocloud.io/docker.io/library/redis:7-alpine
# RABBITMQ_IMAGE=m.daocloud.io/docker.io/library/rabbitmq:3-management
# PROMETHEUS_IMAGE=m.daocloud.io/docker.io/prom/prometheus:v2.55.0
# GRAFANA_IMAGE=m.daocloud.io/docker.io/grafana/grafana:11.3.0
